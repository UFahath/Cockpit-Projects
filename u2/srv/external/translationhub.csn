{
 "definitions": {
  "SAP.Translation.Hub": {
   "kind": "service",
   "@Capabilities.BatchSupported": false,
   "@Capabilities.KeyAsSegmentSupported": true,
   "@Core.Description": "SAP Translation Hub",
   "@Core.SchemaVersion": "1810",
   "@Core.LongDescription": "To provide users of software in a global market with texts in their own language, translations are required. SAP Translation Hub enables you to draw on SAP's translation experience across multiple products and languages to propose translations for short texts."
  },
  "SAP.Translation.Hub.domains": {
   "kind": "function",
   "params": {
    "search": {
     "@description": "Shows whether a particular domain is available in SAP Translation Hub. Enter all or part of the short description of the domain, for example, ```financial```.",
     "type": "cds.String",
     "@openapi.in": "query"
    },
    "onlyGroups": {
     "@description": "Shows a list of the domain groups that SAP Translation Hub supports. To list the domain groups, enter ```true``` as the value for this parameter. You can use the ID of a domain or a domain group to specify a particular subject area in the '/translate' method.",
     "type": "cds.String",
     "@openapi.in": "query"
    }
   },
   "@Common.Label": "Domains",
   "@Core.Description": "SAP product domains",
   "@Core.LongDescription": "SAP product terminology is organized by domains. Domains are used in the translation process to determine the correct terminology for a given application. <br> This method returns a list of the domains and domain groups that are available in SAP Translation Hub.<br> You can combine the '/domains' method with the '/translate' method to more accurately reflect the subject area of your texts.",
   "@openapi.path": "/domains",
   "returns": {
    "elements": {
     "domains": {
      "type": "SAP.Translation.Hub_types.Domains"
     }
    }
   }
  },
  "SAP.Translation.Hub.languages": {
   "kind": "function",
   "params": {
    "search": {
     "@description": "Determines whether a particular language is available in SAP Translation Hub. You must enter the name, as opposed to the ID, of the language, for example,  ```Bulgarian```.",
     "type": "cds.String",
     "@openapi.in": "query"
    }
   },
   "@Common.Label": "Languages",
   "@Core.Description": "Languages that SAP Translation Hub supports.",
   "@Core.LongDescription": "Returns a list of the languages that SAP Translation Hub supports. You can also check whether a particualr language is available in SAP Translation Hub.",
   "@openapi.path": "/languages",
   "returns": {
    "elements": {
     "languages": {
      "type": "SAP.Translation.Hub_types.Languages"
     }
    }
   }
  },
  "SAP.Translation.Hub.suggestions": {
   "kind": "function",
   "params": {
    "search": {
     "@description": "Allows you to search for a text in SAP Translation Hub in English. You can enter a complete text or part of a text. If you want to search for a text in a language other than English, enter the text in the required language here and specify the language in the *searchLanguage* parameter.",
     "type": "cds.String",
     "@openapi.in": "query",
     "@openapi.required": true
    },
    "searchLanguage": {
     "@description": "Allows you to search for a text in any of the languages that SAP Translation Hub supports. Specify the language using the language ID, for example, de.",
     "type": "cds.String",
     "@openapi.in": "query"
    },
    "language": {
     "@description": "Allows you to search for a text that has translations in the specified language(s). For example, you can search for texts that have translations in German (de) and French (fr).",
     "type": "cds.String",
     "@openapi.in": "query"
    },
    "domain": {
     "@description": "Searches for texts in the specified domain(s) or domain group(s). For example, you can search for terms that are assigned to the domain for Customer Relationship Management (B2) or logistics (03). To see which domains and domain groups are supported, use the '/domains' method.",
     "type": "cds.String",
     "@openapi.in": "query"
    },
    "texttype": {
     "@description": "Allows you to search for a text that is assigned to one or more text types. For example, you can search for terms that are assigned to the text type for field labels (XFLD). To see which text types are supported, use the '/texttypes' method. If you use the suggestion service with ABAP systems, you can specify a four-character object type, such as DTEL for data elements, in this parameter.",
     "type": "cds.String",
     "@openapi.in": "query"
    },
    "maxLength": {
     "@description": "Searches for texts up to the specified number of characters. For example, if a UI element can accommodate only 5 characters, you can search for texts that comprise 5 characters or fewer. If the suggestion service cannot find any texts that match the length criteria, the response is empty.",
     "type": "cds.String",
     "@openapi.in": "query"
    }
   },
   "@Common.Label": "Suggestions",
   "@Core.Description": "The '/suggestions' method enables you to get suggestions for short texts during the development process.",
   "@Core.LongDescription": "Provides suggestions for short texts based on complete or partial texts and their translations. You can, for example, use the '/suggestions' method to propose texts while you type texts in a development environment. The texts that the method proposes are already available in additional languages in the multilingual text repository (MLTR).",
   "@openapi.path": "/suggestions",
   "returns": {
    "elements": {
     "suggestions": {
      "type": "SAP.Translation.Hub_types.Suggestions"
     }
    }
   }
  },
  "SAP.Translation.Hub.texttypes": {
   "kind": "function",
   "params": {
    "search": {
     "@description": "Allows you to search for a specific text type, such as 'message'.",
     "type": "cds.String",
     "@openapi.in": "query"
    }
   },
   "@Common.Label": "Text Types",
   "@Core.Description": "Returns a list of the text types available in SAP Translation Hub.",
   "@Core.LongDescription": "In SAP products, short texts, such as those used on user interfaces (UIs), are characterized by various text types. The type of a specific text is determined by the UI element that it describes. For example,  message texts are described by the text type ```XMSG```. <br> The '/texttypes' method returns a list of the text types that are available in SAP Translation Hub. You can combine the '/texttypes' method with the '/suggestions' method to narrow down the results of the '/suggestions' method.",
   "@openapi.path": "/texttypes",
   "returns": {
    "elements": {
     "texttypes": {
      "type": "SAP.Translation.Hub_types.texttypes"
     }
    }
   }
  },
  "SAP.Translation.Hub.translate_post": {
   "kind": "action",
   "params": {
    "body": {
     "type": "SAP.Translation.Hub_types.Translate",
     "@openapi.in": "body"
    }
   },
   "@Common.Label": "Translate",
   "@Core.Description": "The '/translate' method enables you to get translations of English short texts that exist in SAP Translation Hub.",
   "@Core.LongDescription": "Provides translations of short texts based on a combination of existing texts and their translations that are used in SAP products and machine translation capabilities.",
   "@openapi.path": "/translate",
   "returns": {
    "elements": {
     "units": {
      "type": "SAP.Translation.Hub_types.TranslateResponse"
     }
    }
   }
  },
  "SAP.Translation.Hub_types.Domains": {
   "items": {
    "type": "SAP.Translation.Hub_types.DomainsResponse"
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.DomainsResponse": {
   "elements": {
    "id": {
     "@description": "The ID of a domain or a domain group, depending on whether you use the 'onlyGroups' parameter in the request.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "FI"
    },
    "name": {
     "@description": "The short description of a domain or a domain group, depending on whether you use the 'onlyGroups' parameter in the request.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Financial Accounting"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.Suggestions": {
   "items": {
    "type": "SAP.Translation.Hub_types.SuggestionsResponse"
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.SuggestionsResponse": {
   "elements": {
    "id": {
     "@description": "Uniquely identifies the text's entry in the database.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "0"
    },
    "value": {
     "@description": "The text for which the '/suggestions' method searches in the MLTR based on the text that you enter in the search parameter in the request. For example, let's assume you want to search for 'cancel'. You enter part of that word, for example, 'canc', in the request. The value parameter in the response contains the full text, **cancel**.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Cancel"
    },
    "domainId": {
     "@description": "The ID of the domain assigned to the translations of the text entered in the request. If you specify the ID of a domain group in the request, the response always contains the ID of an individual domain.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "BC"
    },
    "domainName": {
     "@description": "The name of the domain assigned to the translations of the text entered in the request. If you specify the ID of a domain group in the request, the response always contains the name of an individual domain.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Basis"
    },
    "texttypeId": {
     "@description": "The ID of the text type assigned to the text entered in the request. If you use the suggestion service with ABAP systems and the service returns an object type instead of a text type, this parameter shows the four-character ID of the object type.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "XFLD"
    },
    "texttypeName": {
     "@description": "The name of the text type assigned to the text entered in the request. If you use the suggestion service with ABAP systems and the service returns an object type instead of a text type, this parameter shows the name of the object type.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Label"
    },
    "englishValue": {
     "@description": "If you search for a text in English, the content of this parameter is the same as the value parameter. If you search for a text in a language *other* than English, this parameter contains the English translation of the text in the value parameter. The English translation of the text - in English - entered in the request.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Cancel"
    },
    "availableLanguages": {
     "@description": "The total number of languages, including English, in which there are translations of the requested text in SAP Translation Hub.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "39"
    },
    "availableFilteredLanguages": {
     "@description": "If you use the language parameter in the request, this parameter shows the number of languages in that parameter in which translations of the text was found. For example, if you specify French (FR) and German (DE) in the language parameter of the request, but there are translations of the requested text only in French, the value of this key is 1. If there are translations in both French and German, the value of this key is 2.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "1"
    },
    "textSpace": {
     "@description": "Indicates length specifications of the text entered in the request. This parameter is supported only for texts that you search for  in English or German. This means the searchLanguage parameter is English or German, or you do not enter the searchLanguage parameter in the request.",
     "type": "SAP.Translation.Hub_types.textSpace"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.textSpace": {
   "elements": {
    "inputChars": {
     "@description": "The number of characters contained in the text entered in the request.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": 6
    },
    "minRecEm": {
     "@description": "The minimum recommended length to set aside in the UI to accommodate a potential length increase in translations. It is measured in em.      ",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": 11
    },
    "minRecChars": {
     "@description": "The minimum recommended number of characters to set aside in the UI to accommodate a potential length increase in translations.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": 16
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.Translate": {
   "elements": {
    "targetLanguages": {
     "@description": "The codes of the target languages in which you want the method to return translations of texts. To view the IDs of the supported languages, call the SAP Translation Hub '/languages' method. If you do not specify any target languages, the method returns the texts in all available target languages.",
     "items": {
      "type": "cds.String"
     }
    },
    "sourceLanguage": {
     "@description": "Enables you to specify a source language other than English. You can enter the code of any of the languages that SAP Translation Hub supports as a source language. If you do not use this parameter, the API assumes that the source language is English. To see which combinations of source and target languages are supported, see [Supported Languages](https://help.sap.com/docs/translation-hub/sap-translation-hub/supported-languages).",
     "type": "cds.String",
     "default": {
      "val": "en"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "en"
    },
    "enableMT": {
     "@description": "Determines whether SAP Translation Hub translates texts using SAP Machine Translation (SAP MT) in addition to the multilingual text  repository (MLTR). By default, SAP MT is active. If you want to deactivate it, enter ```false``` as the value of this key.",
     "type": "cds.Boolean",
     "default": {
      "val": true
     }
    },
    "statsOnly": {
     "@description": "If this option is set to ```true``` then the language, translationProvider and the qualityIndex will be shown in the translations but not the value. By default, the value of this key is ```false```.",
     "type": "cds.Boolean",
     "default": {
      "val": false
     }
    },
    "minQuality": {
     "@description": "This parameter filters the results such that only the translations whose qulityIndex is greater than or equal to the value mentioned here is displayed. By default, the value of this key is ```0```.",
     "type": "cds.Integer",
     "default": {
      "val": "0"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "70"
    },
    "domain": {
     "@description": "The ID of a translation domain, for example, BC. If you do not specify a domain, the method searches for translations in all available domains.",
     "type": "cds.String",
     "default": {
      "val": "BC"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "BC"
    },
    "companyMLTRId": {
     "@description": "The ID of a company MLTR. To get the ID of a company MLTR, see the address bar of the UI for company MLTRs. For more information, see [Access UIs for Integrating Your Own Language Data](https://help.sap.com/docs/translation-hub/sap-translation-hub/access-uis-for-integrating-your-own-language-data). ",
     "type": "cds.String"
    },
    "units": {
     "items": {
      "type": "SAP.Translation.Hub_types.units"
     }
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.units": {
   "elements": {
    "textType": {
     "@description": "The ID of a text type, for example, XFLD for a field label.",
     "type": "cds.String",
     "default": {
      "val": "XFLD"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "XFLD"
    },
    "key": {
     "@description": "A key that helps you to uniquely identify a particular text and its  subsequent translations in the units key. SAP Translation Hub stores  this key with the text in the service request to make it easier to  identify specific texts and their translations than by using the texts  alone. For example, if you specify a key for each text in a properties  file that you want to translate, you can use the key to identify the  translations for each text in the target properties files.<br>The key  is stored only to make it easier to identify the text in the units key;  it is not stored for future reference in the multilingual text repository.",
     "type": "cds.String",
     "default": {
      "val": "LOGIN_USERNAME_FIELD"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "LOGIN_USERNAME_FIELD"
    },
    "value": {
     "@description": "The text to be translated.",
     "type": "cds.String",
     "default": {
      "val": "User Name"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "User Name",
     "@mandatory": true
    },
    "maxLength": {
     "@description": "The maximum number of characters that you want translations to comprise. Note: If the API is not able to find translations of the required length for at least one target language, the request does not contain any translations.",
     "type": "cds.Integer",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "10"
    },
    "searchData": {
     "@description": "A parameter that allows you to specify the translation of a UI text  in one of the target languages. You use this parameter if you know  that there are multiple possible translations for a given source text, and you want to restrict the results to a specific translation.  For example, take the word 'Cancel'. The German translation could be  'Abbrechen' or 'Stornieren'. If you know that the German translation in a given instance should be 'Abbrechen', you can specify 'Abbrechen'  so that the correct translation in German (and in other languages)  is returned.",
     "type": "SAP.Translation.Hub_types.searchData"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.searchData": {
   "elements": {
    "language": {
     "@description": "The ID of the language in which you want to provide a translation.",
     "type": "cds.String",
     "default": {
      "val": "es"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "es",
     "@mandatory": true
    },
    "value": {
     "@description": "The text in a particular target language, as specified in the  ```language``` key of the ```searchData``` key.",
     "type": "cds.String",
     "default": {
      "val": "Usuario"
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Usuario",
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.unitsTranslateResponse": {
   "elements": {
    "textType": {
     "@description": "The ID of a text type, for example, XFLD for a field label.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "XFLD"
    },
    "domain": {
     "@description": "The ID of a translation domain, for example, BC. If you do not specify a domain, the method searches for translations in all available domains.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "BC"
    },
    "key": {
     "@description": "A key that uniquely identifies a text in the ```units``` key.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "LOGIN_USERNAME_FIELD"
    },
    "value": {
     "@description": "Text to be translated.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "User Name"
    },
    "translations": {
     "@description": "Shows the translated text.",
     "items": {
      "type": "SAP.Translation.Hub_types.translationsTranslateResponse"
     }
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.translationsTranslateResponse": {
   "elements": {
    "language": {
     "@description": "The code of the target language in which the text is translated.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "es"
    },
    "value": {
     "@description": "The translation of the text.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Usuario"
    },
    "translationProvider": {
     "@description": "The source of translated texts; 0 represents the multilingual text repository (MLTR), 1 represents SAP machine translation, and 5 represents a company MLTR.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "0"
    },
    "qualityIndex": {
     "@description": "The quality index helps you to judge the quality of translations. The higher the number on a scale from 0-100, the better the quality.   <br>For more information, see [Quality Index](https://help.sap.com/docs/translation-hub/sap-translation-hub/quality-index)..",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "98"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.TranslateResponse": {
   "items": {
    "type": "SAP.Translation.Hub_types.unitsTranslateResponse"
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.Languages": {
   "items": {
    "type": "SAP.Translation.Hub_types.LanguagesResponse"
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.LanguagesResponse": {
   "elements": {
    "id": {
     "@description": "The ID of a language.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "bg"
    },
    "name": {
     "@description": "The name of the language, for example, ''Bulgarian''.'",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Bulgarian"
    },
    "bcp_47_code": {
     "@description": "The ISO code of the language, compliant with Best Current Practice (BCP) 47.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "bg",
     "@openapi.name": "bcp-47-code"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.texttypes": {
   "items": {
    "type": "SAP.Translation.Hub_types.texttypesResponse"
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.texttypesResponse": {
   "elements": {
    "id": {
     "@description": "The unique identifier of a text type, such as <i>XMSG</i> for message texts.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "XMSG"
    },
    "name": {
     "@description": "The short description of a text type, such as <i>Message text</i>.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Message text"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.languageCodeError": {
   "elements": {
    "message": {
     "@description": "The error message displayed when the language code given in the source language field or the target language field or both is wrong.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Unknown language: cr"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.targetLanguageError": {
   "elements": {
    "code": {
     "type": "cds.Integer",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "99"
    },
    "message": {
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Error when calling translation service. Check the log for more details"
    }
   },
   "kind": "type"
  },
  "SAP.Translation.Hub_types.Error": {
   "elements": {
    "code": {
     "type": "cds.Integer"
    },
    "message": {
     "type": "cds.String"
    },
    "fields": {
     "type": "cds.String"
    }
   },
   "kind": "type"
  }
 },
 "meta": {
  "creator": "cds-import-openapi"
 }
}