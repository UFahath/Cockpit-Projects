
# GET Requests
###########################

### Customers
GET http://localhost:4004/odata/v4/vehicle-management/Customers

### Dealers
GET http://localhost:4004/odata/v4/vehicle-management/Dealers

### States
GET http://localhost:4004/odata/v4/vehicle-management/States

### Vehicles
GET http://localhost:4004/odata/v4/vehicle-management/Vehicles

### Orders
GET http://localhost:4004/odata/v4/vehicle-management/Orders

### Configurations
GET http://localhost:4004/odata/v4/vehicle-management/Configurations

### Logs
GET http://localhost:4004/odata/v4/vehicle-management/Logs

### Read Customer with Orders
GET http://localhost:4004/odata/v4/vehicle-management/Customers('C001')?$expand=orders

### Read Dealer with Vehicles
GET http://localhost:4004/odata/v4/vehicle-management/Dealers('D001')?$expand=vehicles

### Read Vehicle
GET http://localhost:4004/odata/v4/vehicle-management/Vehicles('TN1001')?$expand=dealer,state,orders

### Read Order with Expand
GET http://localhost:4004/odata/v4/vehicle-management/Orders('O003')?$expand=customer,vehicleRef,configuration

### Read Configuration
GET http://localhost:4004/odata/v4/vehicle-management/Configurations('CFG001')?$expand=order

### Read Logs
GET http://localhost:4004/odata/v4/vehicle-management/Logs

###########################

GET http://localhost:4004/odata/v4/vehicle-management/Vehicles('MH1003')?$expand=*

##################

# POST Requests
###########################

### Create Customer
POST http://localhost:4004/odata/v4/vehicle-management/Customers
Content-Type: application/json

{
  "customerId":"C003",
  "firstName":"Abdul",
  "lastName":"Fahath",
  "email":"dummy@example.com",
  "phoneNumber":"9999000033"
}

### Create Dealer
POST http://localhost:4004/odata/v4/vehicle-management/Dealers
Content-Type: application/json

{
  "dealerId":"D003",
  "dealerName":"Nallur Motors",
  "location":"Karnataka",
  "status":"ACTIVE"
}

### Create Vehicle
POST http://localhost:4004/odata/v4/vehicle-management/Vehicles
Content-Type: application/json

{
  "modelName":"Hyoodai",
  "vehicleStatus":"Available",
  "newPrice":1200000,
  "dealer_ID":"D002",
  "state_ID":"S014"
}

### Create MTS Order
POST http://localhost:4004/odata/v4/vehicle-management/Orders
Content-Type: application/json

{
  "orderId":"O003",
  "orderType":"MTS",
  "customer_customerId":"C002",
  "vehicleRef_vehicleId":"KA1003"
}

### Create Configuration
POST http://localhost:4004/odata/v4/vehicle-management/Configurations
Content-Type: application/json

{
  "configId":"CFG002",
  "modelName":"Honda",
  "color":"White",
  "engineType":"Diesel",
  "order_orderId":"O003"
}

### Create Log Entry
POST http://localhost:4004/odata/v4/vehicle-management/Logs
Content-Type: application/json

{
  "userId":"dealer",
  "action":"READ",
  "entityName":"",
  "timestamp":""
}

