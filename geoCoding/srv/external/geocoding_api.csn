{
 "definitions": {
  "Geocoding": {
   "kind": "service",
   "@Capabilities.BatchSupported": false,
   "@Capabilities.KeyAsSegmentSupported": true,
   "@Core.Description": "Geocoding",
   "@Core.SchemaVersion": "v1",
   "@Core.LongDescription": "The Geocoding API provides a REST endpoint to transform addresses into geographic coordinates."
  },
  "Geocoding.geocode_post": {
   "kind": "action",
   "params": {
    "body": {
     "type": "Geocoding_types.GeoCodeRequest",
     "@openapi.in": "body"
    }
   },
   "@Common.Label": "Geocode",
   "@Core.Description": "Transform multiple addresses into closest-matching geo positions.",
   "@Core.LongDescription": "Returns a list of geo positions including their address label for a list of addresses provided as free-style search strings",
   "@openapi.path": "/geocode",
   "returns": {
    "@description": "See also https://tools.ietf.org/html/rfc7946#section-3.3",
    "elements": {
     "type": {
      "type": "cds.String",
      "@assert.range": true,
      "enum": {
       "FeatureCollection": {}
      }
     },
     "features": {
      "items": {
       "type": "Geocoding_types.GeoCodeFeature"
      }
     }
    }
   }
  },
  "Geocoding.health": {
   "kind": "function",
   "params": {
    "providers": {
     "type": "cds.String",
     "@description": "List of providers that are requested to health check, no providers will be checked if value is set to \"false\"",
     "@openapi.in": "query"
    }
   },
   "@Common.Label": "Service Health",
   "@Core.Description": "health endpoint",
   "@Core.LongDescription": "The health endpoint can be used to determine the service's current status.",
   "@openapi.path": "/health",
   "returns": {
    "elements": {
     "status": {
      "@description": "The service's overall health status. The value is \"UP\", if the service is healthy, and \"CRITICAL\" otherwise.",
      "type": "cds.String",
      "@assert.range": true,
      "enum": {
       "UP": {},
       "CRITICAL": {}
      }
     },
     "timestamp": {
      "@description": "The timestamp (Unix time) when the service reported the healthy status.",
      "type": "cds.Integer",
      "@Core.Example.$Type": "Core.PrimitiveExampleValue",
      "@Core.Example.Value": 1606308415
     },
     "message": {
      "@description": "Message to explain what the reported status means.",
      "type": "cds.String",
      "@Core.Example.$Type": "Core.PrimitiveExampleValue",
      "@Core.Example.Value": "All services are healthy"
     },
     "details": {
      "@description": "An object that contains further details about the checks that lead to the service's reported overall status.",
      "elements": {
       "HERE": {
        "@description": "Contains the results of health checks for the respective HERE service",
        "items": {
         "elements": {
          "service": {
           "@description": "The HERE service whose status was checked (see https://status.here.com/status)",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "geocoding": {}
           }
          },
          "status": {
           "@description": "The status of the checked HERE service. The value is \"OK\", if the third party service is reported as healthy, and \"CRITICAL\" otherwise.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "OK": {},
            "CRITICAL": {}
           }
          },
          "message": {
           "@description": "Message to explain what the reported status means.",
           "type": "common.JSON",
           "@openapi.schema": "{\"example\":\"Service is healthy\"}"
          }
         }
        }
       },
       "ESRI": {
        "@description": "Contains the results of health checks for the respective Esri service.",
        "items": {
         "elements": {
          "service": {
           "@description": "The Esri service whose status was checked.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "geocoding": {}
           }
          },
          "status": {
           "@description": "The status of the checked Esri service. The value is \"OK\", if the third party service is reported as healthy, and \"CRITICAL\" otherwise.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "OK": {},
            "CRITICAL": {}
           }
          },
          "message": {
           "@description": "Message to explain what the reported status means.",
           "type": "common.JSON",
           "@openapi.schema": "{\"example\":\"Service is healthy\"}"
          }
         }
        }
       },
       "PTV": {
        "@description": "Contains the results of health checks for the respective PTV service.",
        "items": {
         "elements": {
          "service": {
           "@description": "The PTV service whose status was checked.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "geocoding": {}
           }
          },
          "status": {
           "@description": "The status of the checked PTV service. The value is \"OK\", if the third party service is reported as healthy, and \"CRITICAL\" otherwise.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "OK": {},
            "CRITICAL": {}
           }
          },
          "message": {
           "@description": "Message to explain what the reported status means.",
           "type": "common.JSON",
           "@openapi.schema": "{\"example\":\"Service is healthy\"}"
          }
         }
        }
       },
       "TOMTOM": {
        "@description": "Contains the results of health checks for the respective TomTom service.",
        "items": {
         "elements": {
          "service": {
           "@description": "The Tomtom service whose status was checked.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "geocoding": {}
           }
          },
          "status": {
           "@description": "The status of the checked TomTom service. The value is \"OK\", if the third party service is reported as healthy, and \"CRITICAL\" otherwise.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "OK": {},
            "CRITICAL": {}
           }
          },
          "message": {
           "@description": "Message to explain what the reported status means.",
           "type": "common.JSON",
           "@openapi.schema": "{\"example\":\"Service is healthy\"}"
          }
         }
        }
       },
       "TRIMBLE": {
        "@description": "Contains the results of health checks for the respective Trimble service.",
        "items": {
         "elements": {
          "service": {
           "@description": "The Trimble service whose status was checked.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "geocoding": {}
           }
          },
          "status": {
           "@description": "The status of the checked Trimble service. The value is \"OK\", if the third party service is reported as healthy, and \"CRITICAL\" otherwise.",
           "type": "cds.String",
           "@assert.range": true,
           "enum": {
            "OK": {},
            "CRITICAL": {}
           }
          },
          "message": {
           "@description": "Message to explain what the reported status means.",
           "type": "common.JSON",
           "@openapi.schema": "{\"example\":\"Service is healthy\"}"
          }
         }
        }
       }
      }
     }
    }
   }
  },
  "Geocoding_types.GeoJSON2DPosition": {
   "@description": "A 2-dimensional position as defined in https://tools.ietf.org/html/rfc7946#section-3.1.1",
   "items": {
    "type": "cds.Decimal"
   },
   "kind": "type"
  },
  "Geocoding_types.GeoJSON2DPoint": {
   "@description": "https://tools.ietf.org/html/rfc7946#section-3.1.2",
   "elements": {
    "type": {
     "type": "cds.String",
     "@assert.range": true,
     "enum": {
      "Point": {}
     },
     "@mandatory": true
    },
    "coordinates": {
     "type": "Geocoding_types.GeoJSON2DPosition",
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "Geocoding_types.GeoCodeRequest": {
   "elements": {
    "credentials": {
     "@description": "Credentials as required by the provider.",
     "elements": {},
     "@openapi.oneOf": "[{\"$ref\":\"#/components/schemas/ApiKey\"}]",
     "@open": true,
     "@mandatory": true
    },
    "addresses": {
     "@description": "Each string represents an address in freestyle text format to be geocoded. The maximum length of an address string and number of addresses in this array depends on the provider support.",
     "items": {
      "type": "Geocoding.anonymous.type0"
     },
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "Geocoding_types.GeoCodeFeature": {
   "@description": "The GeoCodeFeature contains one geo position and matching label as provided by the respective provider.",
   "elements": {
    "type": {
     "type": "cds.String",
     "@assert.range": true,
     "enum": {
      "Feature": {}
     },
     "@mandatory": true
    },
    "geometry": {
     "type": "Geocoding_types.GeoJSON2DPoint",
     "@mandatory": true
    },
    "properties": {
     "elements": {
      "locationLabel": {
       "type": "cds.String",
       "@mandatory": true
      },
      "relevance": {
       "@description": "This is the same value as \"precision.matchScore\" which is the recommended property to retrieve this information from. Please refer to its documentation for a detailed description.",
       "type": "cds.Decimal",
       "@Core.Example.$Type": "Core.PrimitiveExampleValue",
       "@Core.Example.Value": 1,
       "@mandatory": true
      },
      "address": {
       "type": "Geocoding_types.Address",
       "@mandatory": true
      },
      "inputIndex": {
       "@description": "Index of the input address from the request's list of addresses. This allows to attribute geocoded results to their input data.",
       "type": "cds.Decimal",
       "@mandatory": true
      },
      "precision": {
       "type": "Geocoding_types.PrecisionInformation",
       "@mandatory": true
      }
     },
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "Geocoding_types.Address": {
   "@description": "A location represented by an address. The combination of fields that are actually filled may vary and depends on the requested provider.",
   "elements": {
    "Label": {
     "@description": "Assembled address value built out of the parsed address components. In some cases this might be the only filled field.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Bismarckplatz, 69115 Heidelberg, Deutschland"
    },
    "City": {
     "@description": "Input token(s) the parser has categorized as the city part of an address.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Heidelberg"
    },
    "Country": {
     "@description": "ISO 3166-alpha-3 country code",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "DEU"
    },
    "County": {
     "@description": "Input token(s) the parser has categorized as the county part of an address.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Heidelberg"
    },
    "District": {
     "@description": "Input token(s) the parser has categorized as the district part of an address.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Bergheim"
    },
    "HouseNumber": {
     "@description": "Input token(s) the parser has categorized as the house number part of an address.",
     "type": "cds.String"
    },
    "PostalCode": {
     "@description": "Input token(s) the parser has categorized as the postal code part of an address.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "69115"
    },
    "State": {
     "@description": "Input token(s) the parser has categorized as the state part of an address.",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Baden-Württemberg"
    },
    "Street": {
     "@description": "Input token(s) the parser has categorized as the street part of an address (including intersections which are defined by two streets).",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "Bismarckplatz"
    },
    "AdditionalData": {
     "items": {
      "elements": {
       "value": {
        "type": "cds.String"
       },
       "key": {
        "type": "cds.String"
       }
      }
     }
    }
   },
   "kind": "type"
  },
  "Geocoding_types.PrecisionInformation": {
   "@description": "Provides information about the quality and precision of the geocoding result.",
   "elements": {
    "addressType": {
     "@description": "The type of address, based on the highest precision the address could be resolved with. If the value is 'other', no information about the type is available. Please note that not all providers support each type of address.",
     "type": "cds.String",
     "@assert.range": true,
     "enum": {
      "country": {},
      "state": {},
      "county": {},
      "postalCode": {},
      "city": {},
      "district": {},
      "intersection": {},
      "street": {},
      "houseNumberInterpolated": {},
      "houseNumberExact": {},
      "houseNumberWithSupplement": {},
      "other": {}
     },
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "street"
    },
    "matchScore": {
     "@description": "A normalized value between 0 and 1 indicating how well all tokens from the query address string could be matched to the returned address. This value therefore represents the similarity between the query address string and the determined address. The value 1, for example, indicates that all address tokens could be matched exactly. Note: This is the same value as \"relevance\", however \"matchScore\" is the recommended property to use. For provider Trimble, the result is derived from that provider’s “ConfidenceLevel”. Please check out its definition available at https://developer.trimblemaps.com/restful-apis/appendix/glossary/.\n",
     "type": "cds.Decimal",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": 1
    }
   },
   "kind": "type"
  },
  "Geocoding_types.ApiKey": {
   "elements": {
    "provider": {
     "@description": "The provider from which to get the geocoding information. Currently, the following providers are supported: Here, Esri, PTV, TomTom and Trimble. The provider names are case-insensitive.",
     "type": "cds.String",
     "@assert.range": true,
     "enum": {
      "Here": {},
      "Esri": {},
      "PTV": {},
      "TomTom": {},
      "Trimble": {}
     },
     "@mandatory": true
    },
    "api_key": {
     "@description": "The ApiKey to be used for the provider. If its value is 'SAP-KEY', SAP will use established contract agreements with the respective provider. This currently is only supported for the provider HERE, when using Esri, PTV, TomTom and Trimble you need to bring your own api_key.\n",
     "type": "cds.String",
     "@Core.Example.$Type": "Core.PrimitiveExampleValue",
     "@Core.Example.Value": "<customer-specific-api_key> or SAP-KEY",
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "Geocoding_types.DefaultErrorSchema": {
   "elements": {
    "error": {
     "elements": {
      "code": {
       "@description": "Technical code of the error situation",
       "type": "cds.String",
       "@Core.Example.$Type": "Core.PrimitiveExampleValue",
       "@Core.Example.Value": "00000",
       "@mandatory": true
      },
      "message": {
       "@description": "Description of the error",
       "type": "cds.String",
       "@Core.Example.$Type": "Core.PrimitiveExampleValue",
       "@Core.Example.Value": "The request body was not valid.",
       "@mandatory": true
      }
     },
     "@mandatory": true
    }
   },
   "kind": "type"
  },
  "Geocoding.anonymous.type0": {
   "@description": "Address in free-style text format",
   "type": "cds.String",
   "@Core.Example.$Type": "Core.PrimitiveExampleValue",
   "@Core.Example.Value": "Bismarckplatz, Heidelberg, Deutschland",
   "kind": "type"
  },
  "common.JSON": {
   "kind": "type",
   "type": "cds.LargeString"
  }
 },
 "meta": {
  "creator": "cds-import-openapi"
 }
}